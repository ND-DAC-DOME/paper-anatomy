@prefix : <https://w3id.org/paper-anatomy/vocab#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <https://w3id.org/paper-anatomy/vocab#> .

<https://w3id.org/paper-anatomy/vocab> rdf:type owl:Ontology ;
                                        owl:versionIRI <https://w3id.org/paper-anatomy/releases/0.2.0/vocab> ;
                                        <http://purl.org/dc/terms/created> "2026-07-08"^^xsd:date ;
                                        <http://purl.org/dc/terms/creator> <https://orcid.org/0009-0001-6047-385X> ;
                                        <http://purl.org/dc/terms/description> """The Paper Anatomy Vocabulary (PAX): a small vocabulary complementing DoCO, DEO,
FaBiO, the W3C Web Annotation model and PROV-O for describing the anatomy of a
scientific paper — its structural, rhetorical, spatial and part–whole composition. It covers only what those vocabularies do not:
AI-extracted figure semantics (figure type as a SKOS scheme, chart data payloads),
the distinction between a page's sequence position and its printed page label,
spatial-anchoring conveniences (an application profile over oa:ResourceSelection,
deliberately not a conforming Web Annotation), and document components absent from
DoCO (running page headers/footers, printed page-number marks, code blocks).

Design rule: a term is added here ONLY when no suitable term exists in the reused
community vocabularies. See the schema documentation for the full graph design.

Status: testing — not yet registered at w3id.org; under review before publication."""@en ;
                                        <http://purl.org/dc/terms/language> <http://id.loc.gov/vocabulary/iso639-1/en> ;
                                        <http://purl.org/dc/terms/license> <https://creativecommons.org/licenses/by/4.0/> ;
                                        <http://purl.org/dc/terms/modified> "2026-07-14"^^xsd:date ;
                                        <http://purl.org/dc/terms/publisher> <https://w3id.org/paper-anatomy/org/dac-dome> ;
                                        <http://purl.org/dc/terms/title> "Paper Anatomy Vocabulary (PAX)"@en ;
                                        <http://purl.org/vocab/vann/preferredNamespacePrefix> "pax" ;
                                        <http://purl.org/vocab/vann/preferredNamespaceUri> "https://w3id.org/paper-anatomy/vocab#" ;
                                        rdfs:seeAlso <https://github.com/ND-DAC-DOME/paper-anatomy> ;
                                        owl:versionInfo "0.2.0" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/created
<http://purl.org/dc/terms/created> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/creator
<http://purl.org/dc/terms/creator> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/description
<http://purl.org/dc/terms/description> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/language
<http://purl.org/dc/terms/language> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/license
<http://purl.org/dc/terms/license> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/modified
<http://purl.org/dc/terms/modified> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/publisher
<http://purl.org/dc/terms/publisher> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
<http://purl.org/dc/terms/title> rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespacePrefix
<http://purl.org/vocab/vann/preferredNamespacePrefix> rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespaceUri
<http://purl.org/vocab/vann/preferredNamespaceUri> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#prefLabel
<http://www.w3.org/2004/02/skos/core#prefLabel> rdf:type owl:AnnotationProperty .


#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  http://www.w3.org/2004/02/skos/core#inScheme
<http://www.w3.org/2004/02/skos/core#inScheme> rdf:type owl:ObjectProperty .


###  https://schema.org/parentOrganization
<https://schema.org/parentOrganization> rdf:type owl:ObjectProperty .


###  https://w3id.org/paper-anatomy/vocab#figureType
:figureType rdf:type owl:ObjectProperty ;
            rdfs:range <http://www.w3.org/2004/02/skos/core#Concept> ;
            rdfs:comment "The visual kind of a doco:Figure, as classified by a vision model. Values are concepts in pax:FigureTypeScheme; each concept's skos:notation carries the pipeline's original string code."@en ;
            rdfs:isDefinedBy <https://w3id.org/paper-anatomy/vocab> ;
            rdfs:label "figure type"@en .


###  https://w3id.org/paper-anatomy/vocab#onPage
:onPage rdf:type owl:ObjectProperty ;
        rdfs:range <http://purl.org/spar/fabio/Page> ;
        rdfs:comment "Links a document element to the fabio:Page it appears on. Redundant with the page reachable through pax:region / oa:hasSource, kept as a direct hop for query convenience."@en ;
        rdfs:isDefinedBy <https://w3id.org/paper-anatomy/vocab> ;
        rdfs:label "on page"@en .


###  https://w3id.org/paper-anatomy/vocab#region
:region rdf:type owl:ObjectProperty ;
        rdfs:range <http://www.w3.org/ns/oa#ResourceSelection> ;
        rdfs:comment "Links a document element to an oa:ResourceSelection (source + FragmentSelector with a Media Fragments xywh value) anchoring it to a rectangular region of a page image. This is a compact APPLICATION PROFILE reusing Web Annotation vocabulary components; it is deliberately NOT a conforming oa:Annotation and will not be consumed as-is by generic annotation clients. A lossless transform to conforming Annotations is possible. One element may carry several regions when it spans columns or pages. Coordinates are in the pixel space whose dimensions are given by pax:pageImageWidth/Height on the page."@en ;
        rdfs:isDefinedBy <https://w3id.org/paper-anatomy/vocab> ;
        rdfs:label "region"@en .


#################################################################
#    Data properties
#################################################################

###  http://www.w3.org/2004/02/skos/core#notation
<http://www.w3.org/2004/02/skos/core#notation> rdf:type owl:DatatypeProperty .


###  http://xmlns.com/foaf/0.1/name
<http://xmlns.com/foaf/0.1/name> rdf:type owl:DatatypeProperty .


###  https://w3id.org/paper-anatomy/vocab#chartData
:chartData rdf:type owl:DatatypeProperty ;
           rdfs:comment "The structured data extracted from a chart-type figure (axes, series, data points, error bars), embedded verbatim as a JSON literal (rdf:JSON, JSON-LD 1.1 '@json'). Immutable extraction evidence — payload, not graph structure. No rdfs:range is declared: rdf:JSON is outside the OWL 2 datatype map, and a range axiom would push the vocabulary out of the DL profile. Normalized point nodes may complement (not replace) this when cross-paper SPARQL querying, per-point provenance, or unit alignment is required."@en ;
           rdfs:isDefinedBy <https://w3id.org/paper-anatomy/vocab> ;
           rdfs:label "chart data"@en .


###  https://w3id.org/paper-anatomy/vocab#level
:level rdf:type owl:DatatypeProperty ;
       rdfs:range xsd:string ;
       rdfs:comment "The classified level of a heading: title, label, section, or subsection. Applies to doco:Section and doco:Label nodes."@en ;
       rdfs:isDefinedBy <https://w3id.org/paper-anatomy/vocab> ;
       rdfs:label "heading level"@en .


###  https://w3id.org/paper-anatomy/vocab#matter
:matter rdf:type owl:DatatypeProperty ;
        rdfs:range xsd:string ;
        rdfs:comment "Which matter a heading belongs to: front, body, or back. Convenience mirror of containment in doco:FrontMatter / doco:BodyMatter / doco:BackMatter; applies to doco:Section and doco:Label nodes."@en ;
        rdfs:isDefinedBy <https://w3id.org/paper-anatomy/vocab> ;
        rdfs:label "matter"@en .


###  https://w3id.org/paper-anatomy/vocab#pageEnd
:pageEnd rdf:type owl:DatatypeProperty ;
         rdfs:range xsd:integer ;
         rdfs:comment "Last page (sequence number) on which the section or label appears. Materialized projection; must agree with element containment and page membership."@en ;
         rdfs:isDefinedBy <https://w3id.org/paper-anatomy/vocab> ;
         rdfs:label "page end"@en .


###  https://w3id.org/paper-anatomy/vocab#pageImageHeight
:pageImageHeight rdf:type owl:DatatypeProperty ;
                 rdfs:domain <http://purl.org/spar/fabio/Page> ;
                 rdfs:range xsd:integer ;
                 rdfs:comment "Pixel height of the rendered page image referenced by schema:image — the vertical extent of the coordinate space used by all xywh selectors on this page."@en ;
                 rdfs:isDefinedBy <https://w3id.org/paper-anatomy/vocab> ;
                 rdfs:label "page image height"@en .


###  https://w3id.org/paper-anatomy/vocab#pageImageWidth
:pageImageWidth rdf:type owl:DatatypeProperty ;
                rdfs:domain <http://purl.org/spar/fabio/Page> ;
                rdfs:range xsd:integer ;
                rdfs:comment "Pixel width of the rendered page image referenced by schema:image — the horizontal extent of the coordinate space used by all xywh selectors on this page."@en ;
                rdfs:isDefinedBy <https://w3id.org/paper-anatomy/vocab> ;
                rdfs:label "page image width"@en .


###  https://w3id.org/paper-anatomy/vocab#pageStart
:pageStart rdf:type owl:DatatypeProperty ;
           rdfs:range xsd:integer ;
           rdfs:comment "First page (sequence number) on which the section or label appears. Materialized projection; must agree with element containment and page membership."@en ;
           rdfs:isDefinedBy <https://w3id.org/paper-anatomy/vocab> ;
           rdfs:label "page start"@en .


###  https://w3id.org/paper-anatomy/vocab#parsedContent
:parsedContent rdf:type owl:DatatypeProperty ;
               rdfs:range xsd:string ;
               rdfs:comment "The OCR model's own parse of a figure or table (typically an HTML rendering of a table), preserved verbatim."@en ;
               rdfs:isDefinedBy <https://w3id.org/paper-anatomy/vocab> ;
               rdfs:label "parsed content"@en .


###  https://w3id.org/paper-anatomy/vocab#printedPageLabel
:printedPageLabel rdf:type owl:DatatypeProperty ;
                  rdfs:domain <http://purl.org/spar/fabio/Page> ;
                  rdfs:range xsd:string ;
                  rdfs:comment "The page label exactly as printed on the page, as detected by a vision model. AUTHORITATIVE value; may be non-numeric (roman numerals, 'S12', '266a'). Distinct from schema:position (the page's 1-based sequence in the file)."@en ;
                  rdfs:isDefinedBy <https://w3id.org/paper-anatomy/vocab> ;
                  rdfs:label "printed page label"@en .


###  https://w3id.org/paper-anatomy/vocab#printedPageNumber
:printedPageNumber rdf:type owl:DatatypeProperty ;
                   rdfs:domain <http://purl.org/spar/fabio/Page> ;
                   rdfs:range xsd:integer ;
                   rdfs:comment "A numeric page identifier parsed from pax:printedPageLabel, when available. The label remains authoritative; this integer is a convenience for numeric comparison and may be derived from composite labels (e.g. the 1 in '1 / 21')."@en ;
                   rdfs:isDefinedBy <https://w3id.org/paper-anatomy/vocab> ;
                   rdfs:label "printed page number"@en ;
                   rdfs:seeAlso :printedPageLabel .


###  https://w3id.org/paper-anatomy/vocab#printedPagePosition
:printedPagePosition rdf:type owl:DatatypeProperty ;
                     rdfs:domain <http://purl.org/spar/fabio/Page> ;
                     rdfs:range xsd:string ;
                     rdfs:comment "Where on the page the printed page label appears: top, bottom, left, right."@en ;
                     rdfs:isDefinedBy <https://w3id.org/paper-anatomy/vocab> ;
                     rdfs:label "printed page position"@en .


###  https://w3id.org/paper-anatomy/vocab#rawType
:rawType rdf:type owl:DatatypeProperty ;
         rdfs:range xsd:string ;
         rdfs:comment "The element-type string exactly as emitted by the OCR/layout model, preserved when it differs from (or cannot be mapped to) the RDF class chosen for the element."@en ;
         rdfs:isDefinedBy <https://w3id.org/paper-anatomy/vocab> ;
         rdfs:label "raw type"@en .


#################################################################
#    Classes
#################################################################

###  http://purl.org/spar/fabio/Page
<http://purl.org/spar/fabio/Page> rdf:type owl:Class .


###  http://purl.org/vocommons/voaf#Vocabulary
<http://purl.org/vocommons/voaf#Vocabulary> rdf:type owl:Class .


###  http://www.w3.org/2004/02/skos/core#Concept
<http://www.w3.org/2004/02/skos/core#Concept> rdf:type owl:Class .


###  http://www.w3.org/2004/02/skos/core#ConceptScheme
<http://www.w3.org/2004/02/skos/core#ConceptScheme> rdf:type owl:Class .


###  http://www.w3.org/ns/oa#ResourceSelection
<http://www.w3.org/ns/oa#ResourceSelection> rdf:type owl:Class .


###  http://xmlns.com/foaf/0.1/Organization
<http://xmlns.com/foaf/0.1/Organization> rdf:type owl:Class .


###  http://xmlns.com/foaf/0.1/Person
<http://xmlns.com/foaf/0.1/Person> rdf:type owl:Class .


###  https://w3id.org/paper-anatomy/vocab#CodeBlock
:CodeBlock rdf:type owl:Class ;
           rdfs:comment "A block of source code or pseudo-code presented as a distinct layout element."@en ;
           rdfs:isDefinedBy <https://w3id.org/paper-anatomy/vocab> ;
           rdfs:label "code block"@en .


###  https://w3id.org/paper-anatomy/vocab#OtherElement
:OtherElement rdf:type owl:Class ;
              rdfs:comment "Fallback class for layout elements whose OCR-reported type maps to no known class. The original type string is preserved via pax:rawType."@en ;
              rdfs:isDefinedBy <https://w3id.org/paper-anatomy/vocab> ;
              rdfs:label "other element"@en ;
              rdfs:seeAlso :rawType .


###  https://w3id.org/paper-anatomy/vocab#PageFooter
:PageFooter rdf:type owl:Class ;
            rdfs:comment "A running footer at the bottom of a page (e.g. journal name, copyright line). Semantic source: TEI <fw type='footer'>."@en ;
            rdfs:isDefinedBy <https://w3id.org/paper-anatomy/vocab> ;
            rdfs:label "page footer"@en ;
            rdfs:seeAlso <https://tei-c.org/release/doc/tei-p5-doc/en/html/ref-fw.html> .


###  https://w3id.org/paper-anatomy/vocab#PageHeader
:PageHeader rdf:type owl:Class ;
            rdfs:comment "A running header at the top of a page (e.g. abbreviated title, authors). Not covered by DoCO, whose orb:Header equivalence concerns front matter, not running heads. Semantic source: TEI <fw type='header'>."@en ;
            rdfs:isDefinedBy <https://w3id.org/paper-anatomy/vocab> ;
            rdfs:label "page header"@en ;
            rdfs:seeAlso <http://purl.org/spar/doco/FrontMatter> ,
                         <https://tei-c.org/release/doc/tei-p5-doc/en/html/ref-fw.html> .


###  https://w3id.org/paper-anatomy/vocab#PageNumberMark
:PageNumberMark rdf:type owl:Class ;
                rdfs:comment "The printed page-number glyph detected on a page, as a layout element. The label it denotes is recorded on the page node via pax:printedPageLabel; this class types the mark itself (its region on the page). Semantic source: TEI <fw type='pageNum'>."@en ;
                rdfs:isDefinedBy <https://w3id.org/paper-anatomy/vocab> ;
                rdfs:label "page number mark"@en ;
                rdfs:seeAlso <https://tei-c.org/release/doc/tei-p5-doc/en/html/ref-fw.html> ,
                             :printedPageLabel .


