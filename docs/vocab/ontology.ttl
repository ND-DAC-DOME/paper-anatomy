                 rdfs:label "histogram"@en ;
                 <http://www.w3.org/2004/02/skos/core#prefLabel> "histogram"@en .


###  https://w3id.org/paper-anatomy/vocab#lineGraph
:lineGraph rdf:type owl:NamedIndividual ,
                    <http://www.w3.org/2004/02/skos/core#Concept> ;
           <http://www.w3.org/2004/02/skos/core#inScheme> :FigureTypeScheme ;
           <http://www.w3.org/2004/02/skos/core#notation> "line_graph" ;
           rdfs:label "line graph"@en ;
           <http://www.w3.org/2004/02/skos/core#prefLabel> "line graph"@en .


