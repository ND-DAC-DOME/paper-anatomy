###  https://w3id.org/paper-anatomy/vocab#FigureTypeScheme
:FigureTypeScheme rdf:type owl:NamedIndividual ,
                           <http://www.w3.org/2004/02/skos/core#ConceptScheme> ;
                  <http://purl.org/dc/terms/description> "Controlled values for pax:figureType, mirroring the pipeline's figure classification labels."@en ;
                  <http://purl.org/dc/terms/title> "Figure type scheme"@en ;
                  rdfs:label "figure type scheme"@en .


###  https://w3id.org/paper-anatomy/vocab#barChart
:barChart rdf:type owl:NamedIndividual ,
                   <http://www.w3.org/2004/02/skos/core#Concept> ;
          <http://www.w3.org/2004/02/skos/core#inScheme> :FigureTypeScheme ;
          <http://www.w3.org/2004/02/skos/core#notation> "bar_chart" ;
          rdfs:label "bar chart"@en ;
          <http://www.w3.org/2004/02/skos/core#prefLabel> "bar chart"@en .


###  https://w3id.org/paper-anatomy/vocab#boxplotFigure
:boxplotFigure rdf:type owl:NamedIndividual ,
                        <http://www.w3.org/2004/02/skos/core#Concept> ;
               <http://www.w3.org/2004/02/skos/core#inScheme> :FigureTypeScheme ;
