    "@language" : "en",
    "@value" : "printed page label"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.w3.org/2001/XMLSchema#string"
  } ]
}, {
  "@id" : "https://w3id.org/paper-anatomy/vocab#printedPageNumber",
  "@type" : [ "http://www.w3.org/2002/07/owl#DatatypeProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A numeric page identifier parsed from pax:printedPageLabel, when available. The label remains authoritative; this integer is a convenience for numeric comparison and may be derived from composite labels (e.g. the 1 in '1 / 21')."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://purl.org/spar/fabio/Page"
