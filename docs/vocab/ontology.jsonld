}, {
  "@id" : "https://w3id.org/paper-anatomy/vocab",
  "@type" : [ "http://www.w3.org/2002/07/owl#Ontology", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://purl.org/dc/terms/created" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#date",
    "@value" : "2026-07-08"
  } ],
  "http://purl.org/dc/terms/creator" : [ {
    "@id" : "https://orcid.org/0009-0001-6047-385X"
  } ],
  "http://purl.org/dc/terms/description" : [ {
    "@language" : "en",
    "@value" : "The Paper Anatomy Vocabulary (PAX): a small vocabulary complementing DoCO, DEO,\nFaBiO, the W3C Web Annotation model and PROV-O for describing the anatomy of a\nscientific paper — its structural, rhetorical, spatial and part–whole composition. It covers only what those vocabularies do not:\nAI-extracted figure semantics (figure type as a SKOS scheme, chart data payloads),\nthe distinction between a page's sequence position and its printed page label,\nspatial-anchoring conveniences (an application profile over oa:ResourceSelection,\ndeliberately not a conforming Web Annotation), and document components absent from\nDoCO (running page headers/footers, printed page-number marks, code blocks).\n\nDesign rule: a term is added here ONLY when no suitable term exists in the reused\ncommunity vocabularies. See the schema documentation for the full graph design.\n\nStatus: testing — not yet registered at w3id.org; under review before publication."
  } ],
  "http://purl.org/dc/terms/language" : [ {
    "@id" : "http://id.loc.gov/vocabulary/iso639-1/en"
  } ],
  "http://purl.org/dc/terms/license" : [ {
    "@id" : "https://creativecommons.org/licenses/by/4.0/"
  } ],
  "http://purl.org/dc/terms/modified" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#date",
    "@value" : "2026-07-14"
  } ],
  "http://purl.org/dc/terms/publisher" : [ {
    "@id" : "https://w3id.org/paper-anatomy/org/dac-dome"
  } ],
  "http://purl.org/dc/terms/title" : [ {
    "@language" : "en",
    "@value" : "Paper Anatomy Vocabulary (PAX)"
  } ],
  "http://purl.org/vocab/vann/preferredNamespacePrefix" : [ {
    "@value" : "pax"
  } ],
  "http://purl.org/vocab/vann/preferredNamespaceUri" : [ {
    "@value" : "https://w3id.org/paper-anatomy/vocab#"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://purl.org/vocommons/voaf#Vocabulary"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@id" : "https://github.com/ND-DAC-DOME/paper-anatomy"
  } ],
  "http://www.w3.org/2002/07/owl#versionIRI" : [ {
    "@id" : "https://w3id.org/paper-anatomy/releases/0.2.0/vocab"
  } ],
  "http://www.w3.org/2002/07/owl#versionInfo" : [ {
    "@value" : "0.2.0"
  } ]
}, {
  "@id" : "https://w3id.org/paper-anatomy/vocab#CodeBlock",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A block of source code or pseudo-code presented as a distinct layout element."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://w3id.org/paper-anatomy/vocab"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "code block"
  } ]
}, {
  "@id" : "https://w3id.org/paper-anatomy/vocab#FigureTypeScheme",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://purl.org/dc/terms/description" : [ {
    "@language" : "en",
    "@value" : "Controlled values for pax:figureType, mirroring the pipeline's figure classification labels."
  } ],
  "http://purl.org/dc/terms/title" : [ {
    "@language" : "en",
    "@value" : "Figure type scheme"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#ConceptScheme"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "figure type scheme"
  } ]
}, {
  "@id" : "https://w3id.org/paper-anatomy/vocab#OtherElement",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Fallback class for layout elements whose OCR-reported type maps to no known class. The original type string is preserved via pax:rawType."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://w3id.org/paper-anatomy/vocab"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "other element"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@id" : "https://w3id.org/paper-anatomy/vocab#rawType"
  } ]
}, {
  "@id" : "https://w3id.org/paper-anatomy/vocab#PageFooter",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A running footer at the bottom of a page (e.g. journal name, copyright line). Semantic source: TEI <fw type='footer'>."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://w3id.org/paper-anatomy/vocab"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "page footer"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@id" : "https://tei-c.org/release/doc/tei-p5-doc/en/html/ref-fw.html"
  } ]
}, {
  "@id" : "https://w3id.org/paper-anatomy/vocab#PageHeader",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A running header at the top of a page (e.g. abbreviated title, authors). Not covered by DoCO, whose orb:Header equivalence concerns front matter, not running heads. Semantic source: TEI <fw type='header'>."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://w3id.org/paper-anatomy/vocab"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "page header"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@id" : "http://purl.org/spar/doco/FrontMatter"
  }, {
    "@id" : "https://tei-c.org/release/doc/tei-p5-doc/en/html/ref-fw.html"
  } ]
}, {
  "@id" : "https://w3id.org/paper-anatomy/vocab#PageNumberMark",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The printed page-number glyph detected on a page, as a layout element. The label it denotes is recorded on the page node via pax:printedPageLabel; this class types the mark itself (its region on the page). Semantic source: TEI <fw type='pageNum'>."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://w3id.org/paper-anatomy/vocab"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "page number mark"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@id" : "https://tei-c.org/release/doc/tei-p5-doc/en/html/ref-fw.html"
  }, {
    "@id" : "https://w3id.org/paper-anatomy/vocab#printedPageLabel"
  } ]
}, {
  "@id" : "https://w3id.org/paper-anatomy/vocab#barChart",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
