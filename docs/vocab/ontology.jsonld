    "@id" : "https://w3id.org/paper-anatomy/vocab#FigureTypeScheme"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@value" : "bar_chart"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "bar chart"
  } ]
}, {
  "@id" : "https://w3id.org/paper-anatomy/vocab#boxplotFigure",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "box plot"
  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "https://w3id.org/paper-anatomy/vocab#FigureTypeScheme"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@value" : "boxplot"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "box plot"
  } ]
}, {
  "@id" : "https://w3id.org/paper-anatomy/vocab#chartData",
  "@type" : [ "http://www.w3.org/2002/07/owl#DatatypeProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The structured data extracted from a chart-type figure (axes, series, data points, error bars), embedded verbatim as a JSON literal (rdf:JSON, JSON-LD 1.1 '@json'). Immutable extraction evidence — payload, not graph structure. No rdfs:range is declared: rdf:JSON is outside the OWL 2 datatype map, and a range axiom would push the vocabulary out of the DL profile. Normalized point nodes may complement (not replace) this when cross-paper SPARQL querying, per-point provenance, or unit alignment is required."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://w3id.org/paper-anatomy/vocab"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "chart data"
  } ]
}, {
  "@id" : "https://w3id.org/paper-anatomy/vocab#diagramFigure",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "diagram"
  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "https://w3id.org/paper-anatomy/vocab#FigureTypeScheme"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@value" : "diagram"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "diagram"
  } ]
}, {
  "@id" : "https://w3id.org/paper-anatomy/vocab#figureType",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The visual kind of a doco:Figure, as classified by a vision model. Values are concepts in pax:FigureTypeScheme; each concept's skos:notation carries the pipeline's original string code."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://w3id.org/paper-anatomy/vocab"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "figure type"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ]
}, {
  "@id" : "https://w3id.org/paper-anatomy/vocab#flowchartFigure",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "flowchart"
  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
