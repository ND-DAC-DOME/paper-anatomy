}, {
  "@id" : "https://w3id.org/paper-anatomy/vocab#level",
  "@type" : [ "http://www.w3.org/2002/07/owl#DatatypeProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The classified level of a heading: title, label, section, or subsection. Applies to doco:Section and doco:Label nodes."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://w3id.org/paper-anatomy/vocab"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "heading level"
  } ],
