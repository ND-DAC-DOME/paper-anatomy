<?xml version="1.0"?>
<rdf:RDF xmlns="https://w3id.org/paper-anatomy/vocab#"
     xml:base="https://w3id.org/paper-anatomy/vocab"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:foaf="http://xmlns.com/foaf/0.1/"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:vann="http://purl.org/vocab/vann/"
     xmlns:terms="http://purl.org/dc/terms/"
     xmlns:schema="https://schema.org/">
    <owl:Ontology rdf:about="https://w3id.org/paper-anatomy/vocab">
        <owl:versionIRI rdf:resource="https://w3id.org/paper-anatomy/releases/0.2.0/vocab"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-07-08</terms:created>
        <terms:creator rdf:resource="https://orcid.org/0009-0001-6047-385X"/>
        <terms:description xml:lang="en">The Paper Anatomy Vocabulary (PAX): a small vocabulary complementing DoCO, DEO,
FaBiO, the W3C Web Annotation model and PROV-O for describing the anatomy of a
scientific paper — its structural, rhetorical, spatial and part–whole composition. It covers only what those vocabularies do not:
AI-extracted figure semantics (figure type as a SKOS scheme, chart data payloads),
the distinction between a page&apos;s sequence position and its printed page label,
spatial-anchoring conveniences (an application profile over oa:ResourceSelection,
deliberately not a conforming Web Annotation), and document components absent from
DoCO (running page headers/footers, printed page-number marks, code blocks).

Design rule: a term is added here ONLY when no suitable term exists in the reused
community vocabularies. See the schema documentation for the full graph design.

Status: testing — not yet registered at w3id.org; under review before publication.</terms:description>
        <terms:language rdf:resource="http://id.loc.gov/vocabulary/iso639-1/en"/>
        <terms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-07-14</terms:modified>
        <terms:publisher rdf:resource="https://w3id.org/paper-anatomy/org/dac-dome"/>
        <terms:title xml:lang="en">Paper Anatomy Vocabulary (PAX)</terms:title>
        <vann:preferredNamespacePrefix>pax</vann:preferredNamespacePrefix>
        <vann:preferredNamespaceUri>https://w3id.org/paper-anatomy/vocab#</vann:preferredNamespaceUri>
        <rdfs:seeAlso rdf:resource="https://github.com/ND-DAC-DOME/paper-anatomy"/>
        <owl:versionInfo>0.2.0</owl:versionInfo>
    </owl:Ontology>
    


