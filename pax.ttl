@prefix pax:     <https://w3id.org/paper-anatomy/vocab#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix vann:    <http://purl.org/vocab/vann/> .
@prefix voaf:    <http://purl.org/vocommons/voaf#> .
@prefix foaf:    <http://xmlns.com/foaf/0.1/> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix oa:      <http://www.w3.org/ns/oa#> .
@prefix fabio:   <http://purl.org/spar/fabio/> .
@prefix doco:    <http://purl.org/spar/doco/> .
@prefix schema:  <https://schema.org/> .

#################################################################
# Ontology header
#################################################################

<https://w3id.org/paper-anatomy/vocab> a owl:Ontology , voaf:Vocabulary ;
    dcterms:title "Paper Anatomy Vocabulary (PAX)"@en ;
    dcterms:description """The Paper Anatomy Vocabulary (PAX): a small vocabulary complementing DoCO, DEO,
FaBiO, the W3C Web Annotation model and PROV-O for describing the anatomy of a
scientific paper — its structural, rhetorical, spatial and part–whole composition. It covers only what those vocabularies do not:
AI-extracted figure semantics (figure type as a SKOS scheme, chart data payloads),
the distinction between a page's sequence position and its printed page label,
spatial-anchoring conveniences (an application profile over oa:ResourceSelection,
deliberately not a conforming Web Annotation), and document components absent from
DoCO (running page headers/footers, printed page-number marks, code blocks).

Design rule: a term is added here ONLY when no suitable term exists in the reused
community vocabularies. See the schema documentation for the full graph design.

Status: testing — not yet registered at w3id.org; under review before publication."""@en ;
    dcterms:created "2026-07-08"^^xsd:date ;
    dcterms:modified "2026-07-14"^^xsd:date ;
    dcterms:creator <https://orcid.org/0009-0001-6047-385X> ;
    dcterms:publisher <https://w3id.org/paper-anatomy/org/dac-dome> ;
    dcterms:language <http://id.loc.gov/vocabulary/iso639-1/en> ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    owl:versionInfo "0.2.0" ;
    owl:versionIRI <https://w3id.org/paper-anatomy/releases/0.2.0/vocab> ;
    vann:preferredNamespacePrefix "pax" ;
    vann:preferredNamespaceUri "https://w3id.org/paper-anatomy/vocab#" ;
    rdfs:seeAlso <https://github.com/ND-DAC-DOME/paper-anatomy> .

<https://orcid.org/0009-0001-6047-385X> a foaf:Person ;
    rdfs:label "Priscila Saboia Moreira" ;
    foaf:name "Priscila Saboia Moreira" .

<https://w3id.org/paper-anatomy/org/dac-dome> a foaf:Organization ;
    rdfs:label "DAC DOME (Data, Operations, Modeling, and Engineering)" ;
    foaf:name "DAC DOME (Data, Operations, Modeling, and Engineering)" ;
    schema:parentOrganization <https://ror.org/00mkhxb43> .

<https://ror.org/00mkhxb43> a foaf:Organization ;
    rdfs:label "University of Notre Dame" ;
    foaf:name "University of Notre Dame" .

#################################################################
# Declarations for external terms used by this vocabulary
# (OWL 2 DL requires knowing each IRI's category; without these,
#  OWLAPI guesses and reports punning violations)
#################################################################

dcterms:title       a owl:AnnotationProperty .
dcterms:description a owl:AnnotationProperty .
dcterms:created     a owl:AnnotationProperty .
dcterms:modified    a owl:AnnotationProperty .
dcterms:creator     a owl:AnnotationProperty .
dcterms:publisher   a owl:AnnotationProperty .
dcterms:language    a owl:AnnotationProperty .
dcterms:license     a owl:AnnotationProperty .
vann:preferredNamespacePrefix a owl:AnnotationProperty .
vann:preferredNamespaceUri    a owl:AnnotationProperty .

voaf:Vocabulary        a owl:Class .
skos:Concept           a owl:Class .
skos:ConceptScheme     a owl:Class .
skos:inScheme          a owl:ObjectProperty .
skos:prefLabel         a owl:AnnotationProperty .
skos:notation          a owl:DatatypeProperty .
foaf:Person            a owl:Class .
foaf:Organization      a owl:Class .
foaf:name              a owl:DatatypeProperty .
schema:parentOrganization a owl:ObjectProperty .
oa:ResourceSelection   a owl:Class .
fabio:Page             a owl:Class .

#################################################################
# Classes — document components absent from DoCO
# (verified against the DoCO spec: no generic superclass to anchor
#  to, and no classes for running headers/footers or page-number
#  marks; TEI's <fw> "forme work" element covers this material in
#  XML and is linked as the semantic source)
#################################################################

pax:PageHeader a owl:Class ;
    rdfs:label "page header"@en ;
    rdfs:comment "A running header at the top of a page (e.g. abbreviated title, authors). Not covered by DoCO, whose orb:Header equivalence concerns front matter, not running heads. Semantic source: TEI <fw type='header'>."@en ;
    rdfs:seeAlso <https://tei-c.org/release/doc/tei-p5-doc/en/html/ref-fw.html> , doco:FrontMatter ;
    rdfs:isDefinedBy <https://w3id.org/paper-anatomy/vocab> .

pax:PageFooter a owl:Class ;
    rdfs:label "page footer"@en ;
    rdfs:comment "A running footer at the bottom of a page (e.g. journal name, copyright line). Semantic source: TEI <fw type='footer'>."@en ;
    rdfs:seeAlso <https://tei-c.org/release/doc/tei-p5-doc/en/html/ref-fw.html> ;
    rdfs:isDefinedBy <https://w3id.org/paper-anatomy/vocab> .

pax:PageNumberMark a owl:Class ;
    rdfs:label "page number mark"@en ;
    rdfs:comment "The printed page-number glyph detected on a page, as a layout element. The label it denotes is recorded on the page node via pax:printedPageLabel; this class types the mark itself (its region on the page). Semantic source: TEI <fw type='pageNum'>."@en ;
    rdfs:seeAlso <https://tei-c.org/release/doc/tei-p5-doc/en/html/ref-fw.html> , pax:printedPageLabel ;
    rdfs:isDefinedBy <https://w3id.org/paper-anatomy/vocab> .

pax:CodeBlock a owl:Class ;
    rdfs:label "code block"@en ;
    rdfs:comment "A block of source code or pseudo-code presented as a distinct layout element."@en ;
    rdfs:isDefinedBy <https://w3id.org/paper-anatomy/vocab> .

pax:OtherElement a owl:Class ;
    rdfs:label "other element"@en ;
    rdfs:comment "Fallback class for layout elements whose OCR-reported type maps to no known class. The original type string is preserved via pax:rawType."@en ;
    rdfs:seeAlso pax:rawType ;
    rdfs:isDefinedBy <https://w3id.org/paper-anatomy/vocab> .

#################################################################
# Object properties — spatial anchoring conveniences
#################################################################

pax:region a owl:ObjectProperty ;
    rdfs:label "region"@en ;
    rdfs:comment "Links a document element to an oa:ResourceSelection (source + FragmentSelector with a Media Fragments xywh value) anchoring it to a rectangular region of a page image. This is a compact APPLICATION PROFILE reusing Web Annotation vocabulary components; it is deliberately NOT a conforming oa:Annotation and will not be consumed as-is by generic annotation clients. A lossless transform to conforming Annotations is possible. One element may carry several regions when it spans columns or pages. Coordinates are in the pixel space whose dimensions are given by pax:pageImageWidth/Height on the page."@en ;
    rdfs:range oa:ResourceSelection ;
    rdfs:isDefinedBy <https://w3id.org/paper-anatomy/vocab> .

pax:onPage a owl:ObjectProperty ;
    rdfs:label "on page"@en ;
    rdfs:comment "Links a document element to the fabio:Page it appears on. Redundant with the page reachable through pax:region / oa:hasSource, kept as a direct hop for query convenience."@en ;
    rdfs:range fabio:Page ;
    rdfs:isDefinedBy <https://w3id.org/paper-anatomy/vocab> .

pax:figureType a owl:ObjectProperty ;
    rdfs:label "figure type"@en ;
    rdfs:comment "The visual kind of a doco:Figure, as classified by a vision model. Values are concepts in pax:FigureTypeScheme; each concept's skos:notation carries the pipeline's original string code."@en ;
    rdfs:range skos:Concept ;
    rdfs:isDefinedBy <https://w3id.org/paper-anatomy/vocab> .

#################################################################
# Figure-type SKOS concept scheme
#################################################################

pax:FigureTypeScheme a skos:ConceptScheme ;
    rdfs:label "figure type scheme"@en ;
    dcterms:title "Figure type scheme"@en ;
    dcterms:description "Controlled values for pax:figureType, mirroring the pipeline's figure classification labels."@en .

pax:barChart a skos:Concept ; skos:inScheme pax:FigureTypeScheme ;
    rdfs:label "bar chart"@en ; skos:prefLabel "bar chart"@en ; skos:notation "bar_chart" .
pax:lineGraph a skos:Concept ; skos:inScheme pax:FigureTypeScheme ;
    rdfs:label "line graph"@en ; skos:prefLabel "line graph"@en ; skos:notation "line_graph" .
pax:scatterPlot a skos:Concept ; skos:inScheme pax:FigureTypeScheme ;
    rdfs:label "scatter plot"@en ; skos:prefLabel "scatter plot"@en ; skos:notation "scatter_plot" .
pax:histogramFigure a skos:Concept ; skos:inScheme pax:FigureTypeScheme ;
    rdfs:label "histogram"@en ; skos:prefLabel "histogram"@en ; skos:notation "histogram" .
pax:heatmapFigure a skos:Concept ; skos:inScheme pax:FigureTypeScheme ;
    rdfs:label "heatmap"@en ; skos:prefLabel "heatmap"@en ; skos:notation "heatmap" .
pax:boxplotFigure a skos:Concept ; skos:inScheme pax:FigureTypeScheme ;
    rdfs:label "box plot"@en ; skos:prefLabel "box plot"@en ; skos:notation "boxplot" .
pax:pieChart a skos:Concept ; skos:inScheme pax:FigureTypeScheme ;
    rdfs:label "pie chart"@en ; skos:prefLabel "pie chart"@en ; skos:notation "pie_chart" .
pax:photograph a skos:Concept ; skos:inScheme pax:FigureTypeScheme ;
    rdfs:label "photograph"@en ; skos:prefLabel "photograph"@en ; skos:notation "photograph" .
pax:micrograph a skos:Concept ; skos:inScheme pax:FigureTypeScheme ;
    rdfs:label "micrograph"@en ; skos:prefLabel "micrograph"@en ; skos:notation "micrograph" .
pax:diagramFigure a skos:Concept ; skos:inScheme pax:FigureTypeScheme ;
    rdfs:label "diagram"@en ; skos:prefLabel "diagram"@en ; skos:notation "diagram" .
pax:flowchartFigure a skos:Concept ; skos:inScheme pax:FigureTypeScheme ;
    rdfs:label "flowchart"@en ; skos:prefLabel "flowchart"@en ; skos:notation "flowchart" .
pax:schematicFigure a skos:Concept ; skos:inScheme pax:FigureTypeScheme ;
    rdfs:label "schematic"@en ; skos:prefLabel "schematic"@en ; skos:notation "schematic" .
pax:mapFigure a skos:Concept ; skos:inScheme pax:FigureTypeScheme ;
    rdfs:label "map"@en ; skos:prefLabel "map"@en ; skos:notation "map" .
pax:otherFigureType a skos:Concept ; skos:inScheme pax:FigureTypeScheme ;
    rdfs:label "other"@en ; skos:prefLabel "other"@en ; skos:notation "other" .

#################################################################
# Datatype properties — AI-extracted payloads
#################################################################

pax:chartData a owl:DatatypeProperty ;
    rdfs:label "chart data"@en ;
    rdfs:comment "The structured data extracted from a chart-type figure (axes, series, data points, error bars), embedded verbatim as a JSON literal (rdf:JSON, JSON-LD 1.1 '@json'). Immutable extraction evidence — payload, not graph structure. No rdfs:range is declared: rdf:JSON is outside the OWL 2 datatype map, and a range axiom would push the vocabulary out of the DL profile. Normalized point nodes may complement (not replace) this when cross-paper SPARQL querying, per-point provenance, or unit alignment is required."@en ;
    rdfs:isDefinedBy <https://w3id.org/paper-anatomy/vocab> .

pax:parsedContent a owl:DatatypeProperty ;
    rdfs:label "parsed content"@en ;
    rdfs:comment "The OCR model's own parse of a figure or table (typically an HTML rendering of a table), preserved verbatim."@en ;
    rdfs:range xsd:string ;
    rdfs:isDefinedBy <https://w3id.org/paper-anatomy/vocab> .

pax:rawType a owl:DatatypeProperty ;
    rdfs:label "raw type"@en ;
    rdfs:comment "The element-type string exactly as emitted by the OCR/layout model, preserved when it differs from (or cannot be mapped to) the RDF class chosen for the element."@en ;
    rdfs:range xsd:string ;
    rdfs:isDefinedBy <https://w3id.org/paper-anatomy/vocab> .

#################################################################
# Datatype properties — page numbering and page-image geometry
# (the KG keeps two numberings distinct: schema:position is the
#  1-based sequence in file order; printedPageLabel is what is
#  printed on the page — possibly non-numeric: "xiii", "S12",
#  "266a". printedPageNumber is a derived integer convenience.)
#################################################################

pax:printedPageLabel a owl:DatatypeProperty ;
    rdfs:label "printed page label"@en ;
    rdfs:comment "The page label exactly as printed on the page, as detected by a vision model. AUTHORITATIVE value; may be non-numeric (roman numerals, 'S12', '266a'). Distinct from schema:position (the page's 1-based sequence in the file)."@en ;
    rdfs:domain fabio:Page ;
    rdfs:range xsd:string ;
    rdfs:isDefinedBy <https://w3id.org/paper-anatomy/vocab> .

pax:printedPageNumber a owl:DatatypeProperty ;
    rdfs:label "printed page number"@en ;
    rdfs:comment "A numeric page identifier parsed from pax:printedPageLabel, when available. The label remains authoritative; this integer is a convenience for numeric comparison and may be derived from composite labels (e.g. the 1 in '1 / 21')."@en ;
    rdfs:domain fabio:Page ;
    rdfs:range xsd:integer ;
    rdfs:seeAlso pax:printedPageLabel ;
    rdfs:isDefinedBy <https://w3id.org/paper-anatomy/vocab> .

pax:printedPagePosition a owl:DatatypeProperty ;
    rdfs:label "printed page position"@en ;
    rdfs:comment "Where on the page the printed page label appears: top, bottom, left, right."@en ;
    rdfs:domain fabio:Page ;
    rdfs:range xsd:string ;
    rdfs:isDefinedBy <https://w3id.org/paper-anatomy/vocab> .

pax:pageImageWidth a owl:DatatypeProperty ;
    rdfs:label "page image width"@en ;
    rdfs:comment "Pixel width of the rendered page image referenced by schema:image — the horizontal extent of the coordinate space used by all xywh selectors on this page."@en ;
    rdfs:domain fabio:Page ;
    rdfs:range xsd:integer ;
    rdfs:isDefinedBy <https://w3id.org/paper-anatomy/vocab> .

pax:pageImageHeight a owl:DatatypeProperty ;
    rdfs:label "page image height"@en ;
    rdfs:comment "Pixel height of the rendered page image referenced by schema:image — the vertical extent of the coordinate space used by all xywh selectors on this page."@en ;
    rdfs:domain fabio:Page ;
    rdfs:range xsd:integer ;
    rdfs:isDefinedBy <https://w3id.org/paper-anatomy/vocab> .

#################################################################
# Datatype properties — heading-classification outputs
# (these are CLASSIFIER OUTPUTS — evaluation targets in their own
#  right — as well as flat conveniences mirroring the structural
#  typing and the po:contains tree. No rdfs:domain is declared:
#  they legitimately apply to doco:Section AND doco:Label nodes,
#  and a Section domain would wrongly entail that labels are
#  sections.)
#################################################################

pax:level a owl:DatatypeProperty ;
    rdfs:label "heading level"@en ;
    rdfs:comment "The classified level of a heading: title, label, section, or subsection. Applies to doco:Section and doco:Label nodes."@en ;
    rdfs:range xsd:string ;
    rdfs:isDefinedBy <https://w3id.org/paper-anatomy/vocab> .

pax:matter a owl:DatatypeProperty ;
    rdfs:label "matter"@en ;
    rdfs:comment "Which matter a heading belongs to: front, body, or back. Convenience mirror of containment in doco:FrontMatter / doco:BodyMatter / doco:BackMatter; applies to doco:Section and doco:Label nodes."@en ;
    rdfs:range xsd:string ;
    rdfs:isDefinedBy <https://w3id.org/paper-anatomy/vocab> .

pax:pageStart a owl:DatatypeProperty ;
    rdfs:label "page start"@en ;
    rdfs:comment "First page (sequence number) on which the section or label appears. Materialized projection; must agree with element containment and page membership."@en ;
    rdfs:range xsd:integer ;
    rdfs:isDefinedBy <https://w3id.org/paper-anatomy/vocab> .

pax:pageEnd a owl:DatatypeProperty ;
    rdfs:label "page end"@en ;
    rdfs:comment "Last page (sequence number) on which the section or label appears. Materialized projection; must agree with element containment and page membership."@en ;
    rdfs:range xsd:integer ;
    rdfs:isDefinedBy <https://w3id.org/paper-anatomy/vocab> .
