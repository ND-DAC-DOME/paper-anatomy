{
  "@context": {
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "dcterms": "http://purl.org/dc/terms/",
    "deo": "http://purl.org/spar/deo/",
    "doco": "http://purl.org/spar/doco/",
    "fabio": "http://purl.org/spar/fabio/",
    "frbr": "http://purl.org/vocab/frbr/core#",
    "linkml": "https://w3id.org/linkml/",
    "oa": "http://www.w3.org/ns/oa#",
    "pax": "https://w3id.org/paper-anatomy/vocab#",
    "paxi": "https://w3id.org/paper-anatomy/linkml/pax-instance/",
    "po": "http://www.essepuntato.it/2008/12/pattern#",
    "prov": "http://www.w3.org/ns/prov#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "sdo": "https://schema.org/",
    "@vocab": "https://w3id.org/paper-anatomy/linkml/pax-instance/",
    "about": {
      "@id": "sdo:about"
    },
    "category": {
      "@id": "category"
    },
    "chartData": {
      "@type": "linkml:Any",
      "@id": "pax:chartData"
    },
    "conformsTo": {
      "@id": "dcterms:conformsTo"
    },
    "contains": {
      "@type": "@id",
      "@id": "po:contains"
    },
    "description": {
      "@id": "dcterms:description"
    },
    "embodiment": {
      "@type": "@id",
      "@id": "frbr:embodiment"
    },
    "embodimentOf": {
      "@id": "frbr:embodimentOf"
    },
    "figureType": {
      "@id": "pax:figureType"
    },
    "hasPart": {
      "@type": "@id",
      "@id": "dcterms:hasPart"
    },
    "hasSelector": {
      "@type": "@id",
      "@id": "oa:hasSelector"
    },
    "hasSource": {
      "@id": "oa:hasSource"
    },
    "id": "@id",
    "identifier": {
      "@id": "dcterms:identifier"
    },
    "image": {
      "@id": "sdo:image"
    },
    "label": {
      "@id": "sdo:name"
    },
    "level": {
      "@id": "pax:level"
    },
    "license": {
      "@id": "dcterms:license"
    },
    "matter": {
      "@id": "pax:matter"
    },
    "name": {
      "@id": "sdo:name"
    },
    "onPage": {
      "@id": "pax:onPage"
    },
    "pageCount": {
      "@type": "xsd:integer",
      "@id": "fabio:hasPageCount"
    },
    "pageEnd": {
      "@type": "xsd:integer",
      "@id": "pax:pageEnd"
    },
    "pageImageHeight": {
      "@type": "xsd:integer",
      "@id": "pax:pageImageHeight"
    },
    "pageImageWidth": {
      "@type": "xsd:integer",
      "@id": "pax:pageImageWidth"
    },
    "pageStart": {
      "@type": "xsd:integer",
      "@id": "pax:pageStart"
    },
    "parsedContent": {
      "@id": "pax:parsedContent"
    },
    "part": {
      "@type": "@id",
      "@id": "frbr:part"
    },
    "position": {
      "@type": "xsd:integer",
      "@id": "sdo:position"
    },
    "printedPageLabel": {
      "@id": "pax:printedPageLabel"
    },
    "printedPageNumber": {
      "@type": "xsd:integer",
      "@id": "pax:printedPageNumber"
    },
    "printedPagePosition": {
      "@id": "pax:printedPagePosition"
    },
    "rawType": {
      "@id": "pax:rawType"
    },
    "region": {
      "@type": "@id",
      "@id": "pax:region"
    },
    "softwareVersion": {
      "@id": "sdo:softwareVersion"
    },
    "source": {
      "@id": "dcterms:source"
    },
    "startedAtTime": {
      "@id": "prov:startedAtTime"
    },
    "supplement": {
      "@type": "@id",
      "@id": "frbr:supplement"
    },
    "supplementOf": {
      "@id": "frbr:supplementOf"
    },
    "text": {
      "@id": "sdo:text"
    },
    "title": {
      "@id": "dcterms:title"
    },
    "used": {
      "@id": "prov:used"
    },
    "value": {
      "@id": "rdf:value"
    },
    "wasAssociatedWith": {
      "@id": "prov:wasAssociatedWith"
    },
    "wasDerivedFrom": {
      "@id": "prov:wasDerivedFrom"
    },
    "wasGeneratedBy": {
      "@id": "prov:wasGeneratedBy"
    },
    "Activity": {
      "@id": "prov:Activity"
    },
    "Box": {
      "@id": "doco:FigureBox"
    },
    "Dataset": {
      "@id": "sdo:Dataset"
    },
    "DocumentElement": {
      "@id": "DocumentElement"
    },
    "FragmentSelector": {
      "@id": "oa:FragmentSelector"
    },
    "Manifestation": {
      "@id": "fabio:DigitalManifestation"
    },
    "Matter": {
      "@id": "Matter"
    },
    "NodeBase": {
      "@id": "NodeBase"
    },
    "Page": {
      "@id": "fabio:Page"
    },
    "PaperExpression": {
      "@id": "fabio:JournalArticle"
    },
    "Region": {
      "@id": "oa:ResourceSelection"
    },
    "Section": {
      "@id": "doco:Section"
    },
    "SoftwareAgent": {
      "@id": "prov:SoftwareAgent"
    },
    "Supplement": {
      "@id": "fabio:SupplementaryInformationFile"
    }
  }
