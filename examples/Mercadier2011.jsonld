    {
      "@id": "https://w3id.org/alexandria/paper/mercadier2011/run/e88f86e/element/19",
      "@type": "doco:Figure",
      "position": 19,
      "onPage": "https://w3id.org/alexandria/paper/mercadier2011/run/e88f86e/page/2",
      "figureType": "pax:mapFigure",
      "description": "This map shows the global distribution of various uranium deposits, categorized by their geological formation type. Different symbols are used to represent deposit types like magmatic, synmetamorphic, unconformity-related, volcanic-related, vein-type, and roll-front deposits.",
      "pax:parsedContent": "<table><tr><td>Location</td><td>Type</td><td>Count</td></tr><tr><td>Athabasca</td><td>Magnetic</td><td>1</td></tr><tr><td>Moore L</td><td>Magnetic</td><td>1</td></tr><tr><td>Mistamisk</td><td>Unconformity-related</td><td>1</td></tr><tr><td>Luthi</td><td>Unconformity-related</td><td>1</td></tr><tr><td>Kola</td><td>Unconformity-related</td><td>1</td></tr><tr><td>Streltsovskoye</td><td>Volcanic-related</td><td>1</td></tr><tr><td>Kazakhstan</td><td>Volcanic-related</td><td>1</td></tr><tr><td>Kawanga</td><td>Volcanic-related</td><td>1</td></tr><tr><td>Kambolgie</td><td>Volcanic-related</td><td>1</td></tr><tr><td>Unconformity-related</td><td>Volcanic-related</td><td>1</td></tr><tr><td>Vein-type</td><td>Volcanic-related</td><td>1</td></tr><tr><td>Roll-front</td><td>Volcanic-related</td><td>1</td></tr></table>",
      "region": [
